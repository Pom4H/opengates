{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-gates.dev/schema/event.schema.json",
  "title": "Gate event",
  "description": "One entry in a gate case's append-only log. Folding the log yields the gate state. A persisted event MUST carry a stable `id` and a monotonic `seq`; hand-authored scenarios may omit them — the loader synthesizes them deterministically.",
  "type": "object",
  "required": ["type", "at", "actor"],
  "properties": {
    "id": { "type": "string", "description": "Stable, unique event id (uuid/ULID). Dedup key for idempotent replay. Required on a persisted event." },
    "seq": { "type": "integer", "minimum": 1, "description": "Monotonic per-case sequence; apply() requires seq === state.seq + 1." },
    "type": { "enum": ["claim.submitted", "evidence.attached", "decision.recorded"] },
    "at": { "type": "string", "format": "date-time" },
    "actor": { "type": "string", "description": "Who emitted the event (party, role or system)." }
  },
  "oneOf": [
    {
      "properties": {
        "type": { "const": "claim.submitted" },
        "claim": { "$ref": "#/$defs/claimInstance" }
      },
      "required": ["claim"]
    },
    {
      "properties": {
        "type": { "const": "evidence.attached" },
        "evidence": { "$ref": "#/$defs/evidenceInstance" }
      },
      "required": ["evidence"]
    },
    {
      "properties": {
        "type": { "const": "decision.recorded" },
        "reviewerRole": { "type": "string", "description": "On the wire this is advisory; the engine binds authority to the gate's reviewer role and (over MCP/HTTP) to the caller's OAuth scope." },
        "outcome": { "enum": ["accepted", "accepted_with_exceptions", "rejected", "returned_for_rework"] },
        "acceptedValues": {
          "type": "object",
          "description": "The quantities the reviewer actually accepted (e.g. surveyed 117, not claimed 120). Money is paid on these.",
          "additionalProperties": { "$ref": "#/$defs/scalar" }
        },
        "note": { "type": "string" }
      },
      "required": ["reviewerRole", "outcome"]
    }
  ],
  "$defs": {
    "scalar": { "type": ["number", "string", "boolean"] },
    "claimInstance": {
      "type": "object",
      "required": ["type", "values"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string" },
        "values": { "type": "object", "additionalProperties": { "$ref": "#/$defs/scalar" } }
      }
    },
    "evidenceInstance": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "values": { "type": "object", "additionalProperties": { "$ref": "#/$defs/scalar" } },
        "ref": { "type": "string" }
      }
    }
  }
}
