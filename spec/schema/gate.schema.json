{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-gates.dev/schema/gate.schema.json",
  "title": "Gate definition",
  "description": "A reusable acceptance pattern: where a claim becomes an accepted fact with consequences.",
  "type": "object",
  "required": ["id", "name", "domain", "claim", "evidence", "checks", "reviewer", "decisions", "consequences"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "description": "Stable identifier, e.g. construction.work-volume-acceptance." },
    "name": { "type": "string" },
    "domain": { "type": "string" },
    "description": { "type": "string" },
    "claim": { "$ref": "#/$defs/claimSchema" },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidenceRequirement" } },
    "checks": { "type": "array", "items": { "$ref": "#/$defs/check" } },
    "reviewer": { "$ref": "#/$defs/reviewer" },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/decisionOutcome" }, "minItems": 1 },
    "consequences": { "type": "array", "items": { "$ref": "#/$defs/consequence" } },
    "sla": { "$ref": "#/$defs/sla" },
    "policy": { "$ref": "#/$defs/policy" }
  },
  "$defs": {
    "decisionOutcome": { "enum": ["accepted", "accepted_with_exceptions", "rejected", "returned_for_rework"] },
    "severity": { "enum": ["blocking", "warning"] },
    "claimSchema": {
      "type": "object",
      "required": ["type", "fields"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "kind"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "kind": { "enum": ["number", "string", "boolean", "date", "zone"] },
              "unit": { "type": "string" },
              "model": { "type": "string", "description": "For kind 'zone': path to the spatial model whose zone ids this field references." },
              "required": { "type": "boolean" }
            }
          }
        }
      }
    },
    "evidenceRequirement": {
      "type": "object",
      "required": ["kind", "required"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "required": { "type": "boolean" },
        "description": { "type": "string" }
      }
    },
    "reviewer": {
      "type": "object",
      "required": ["role"],
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "check": {
      "type": "object",
      "required": ["id", "rule"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "$ref": "#/$defs/severity" },
        "rule": { "enum": ["required_evidence", "field_present", "field_range", "field_pattern", "cross_check", "date_window"] }
      },
      "oneOf": [
        {
          "properties": { "rule": { "const": "required_evidence" }, "kinds": { "type": "array", "items": { "type": "string" }, "minItems": 1 } },
          "required": ["kinds"]
        },
        {
          "properties": { "rule": { "const": "field_present" }, "field": { "type": "string" } },
          "required": ["field"]
        },
        {
          "properties": { "rule": { "const": "field_range" }, "field": { "type": "string" }, "min": { "type": "number" }, "max": { "type": "number" } },
          "required": ["field"]
        },
        {
          "properties": { "rule": { "const": "field_pattern" }, "field": { "type": "string" }, "pattern": { "type": "string", "description": "Anchored regular expression the string field must match (e.g. a zone id ^[A-Z]\\d+-F\\d{2}$)." } },
          "required": ["field", "pattern"]
        },
        {
          "properties": {
            "rule": { "const": "cross_check" },
            "claimField": { "type": "string" },
            "claimUnit": { "type": "string", "description": "Expected unit of the claim field; must match the evidence unit." },
            "evidenceKind": { "type": "string" },
            "evidenceField": { "type": "string", "description": "The TRUSTED REFERENCE value. Relative error is normalized by this, per VIM §2.16 — not by the claim." },
            "evidenceUnitField": { "type": "string", "default": "unit" },
            "uncertaintyField": { "type": "string", "default": "U", "description": "Evidence field carrying the expanded uncertainty U = k·u (JCGM 100 / GUM). When present, the claim must also be within U of the reference." },
            "requireUnitMatch": { "type": "boolean", "default": true },
            "tolerance": { "type": "number", "minimum": 0, "description": "Relative tolerance vs the reference, e.g. 0.05 = 5% of the surveyed value." },
            "absolute": { "type": "number", "minimum": 0, "description": "Absolute tolerance in the evidence unit; combined with relative as 'whichever is greater'." }
          },
          "required": ["claimField", "evidenceKind", "evidenceField"],
          "anyOf": [{ "required": ["tolerance"] }, { "required": ["absolute"] }]
        },
        {
          "properties": {
            "rule": { "const": "date_window" },
            "field": { "type": "string" },
            "start": { "type": "string", "format": "date-time" },
            "end": { "type": "string", "format": "date-time" }
          },
          "required": ["field"]
        }
      ]
    },
    "consequence": {
      "type": "object",
      "required": ["id", "effect", "on"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "on": { "type": "array", "items": { "$ref": "#/$defs/decisionOutcome" }, "minItems": 1 },
        "effect": { "enum": ["money", "right_to_proceed", "risk", "dataset_label"] }
      },
      "oneOf": [
        {
          "properties": {
            "effect": { "const": "money" },
            "basis": { "enum": ["accepted_quantity", "fixed"] },
            "currency": { "type": "string" },
            "quantityField": { "type": "string", "description": "Pay unitPrice per accepted unit of this field." },
            "unitPrice": { "type": "number" },
            "amount": { "type": "number", "description": "Or a fixed amount." },
            "retentionPct": { "type": "number", "minimum": 0, "maximum": 1, "description": "Guarantee retention withheld from gross (guarantee retention)." },
            "retentionCap": { "type": "number", "minimum": 0, "description": "Cap on cumulative retention (major units)." },
            "vatRate": { "type": "number", "minimum": 0, "description": "VAT rate, surfaced as a memo line on the net." },
            "paymentTermsDays": { "type": "integer", "minimum": 0 },
            "estimateLine": { "type": "string", "description": "Contract/estimate line reference (e.g. FER06-01-001-01)." },
            "contractRef": { "type": "string" }
          },
          "required": ["currency"]
        },
        {
          "properties": { "effect": { "const": "right_to_proceed" }, "unlocks": { "type": "string" } },
          "required": ["unlocks"]
        },
        {
          "properties": { "effect": { "const": "risk" }, "assignedTo": { "type": "string" } },
          "required": ["assignedTo"]
        },
        {
          "properties": { "effect": { "const": "dataset_label" }, "dataset": { "type": "string" } },
          "required": ["dataset"]
        }
      ]
    },
    "sla": {
      "type": "object",
      "required": ["reviewWithinHours"],
      "additionalProperties": false,
      "description": "Optional review SLA. dueAt = enqueuedAt + reviewWithinHours; a case past due is escalated and leased first.",
      "properties": {
        "reviewWithinHours": { "type": "number", "minimum": 0 },
        "priority": { "enum": ["low", "normal", "high", "critical"] },
        "escalateToInbox": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autoAcceptWhen": {
          "type": "object",
          "additionalProperties": false,
          "required": ["checksPass"],
          "properties": {
            "checksPass": { "const": true },
            "maxAmount": { "type": "number", "description": "Auto-accept only below this net certified value; derived from the review-vs-leakage break-even (see docs/ECONOMICS.md)." }
          }
        }
      }
    }
  }
}
