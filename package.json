{
  "name": "open-gates",
  "version": "0.0.1",
  "description": "Open Gates — the review-queue server and tooling around the reference fold engine.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": { "node": ">=22.18" },
  "scripts": {
    "serve": "node server.ts",
    "mcp": "node packages/engine/src/mcp/server.ts",
    "token": "node packages/engine/src/token.ts",
    "test": "node --test packages/engine/test/*.test.ts",
    "conformance": "node conformance/run.mjs",
    "conformance:update": "node conformance/run.mjs --update",
    "demo:dispute": "node packages/engine/src/cli.ts examples/construction/gate.json examples/construction/scenario.dispute.json",
    "demo:accept": "node packages/engine/src/cli.ts examples/construction/gate.json examples/construction/scenario.accept.json",
    "demo:remarks": "node packages/engine/src/cli.ts examples/construction/gate.json examples/construction/scenario.remarks.json",
    "demo:logistics": "node packages/engine/src/cli.ts examples/logistics/gate.json examples/logistics/scenario.accept.json",
    "eval": "node eval/replay.mjs examples/construction/gate.json examples/construction/dataset.sample.jsonl",
    "review:example": "node examples/reviewer/poll.mjs"
  }
}
