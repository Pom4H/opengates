{
  "name": "open-gates",
  "version": "0.0.1",
  "description": "Open Gates — the review-queue server and tooling around the reference fold engine.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": { "node": ">=22.18" },
  "scripts": {
    "serve": "node server.ts",
    "token": "node engine/src/queue/token.ts",
    "mcp": "node engine/src/mcp/server.ts",
    "test": "node --test engine/test/*.test.ts",
    "demo:accept": "node engine/src/cli.ts examples/construction/gate.json examples/construction/scenario.accept.json",
    "demo:dispute": "node engine/src/cli.ts examples/construction/gate.json examples/construction/scenario.dispute.json",
    "review:example": "node examples/reviewer/poll.mjs"
  }
}
